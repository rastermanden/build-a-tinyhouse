---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaterialTabel from '../../components/MaterialTabel.astro';
import VaerktojsListe from '../../components/VaerktojsListe.astro';
import Galleri from '../../components/Galleri.astro';
import StepNav from '../../components/StepNav.astro';
import BestillingsMail from '../../components/BestillingsMail.astro';
import materialelister from '../../data/materialelister.json';
import { href } from '../../lib/url';

export async function getStaticPaths() {
  const steps = (await getCollection('steps')).sort((a, b) => a.data.order - b.data.order);
  return steps.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      forrige: i > 0 ? steps[i - 1] : undefined,
      naeste: i < steps.length - 1 ? steps[i + 1] : undefined,
    },
  }));
}

const { entry, forrige, naeste } = Astro.props;
const { Content } = await render(entry);

// Saml billeder for dette step ud fra mappen src/assets/steps/<slug>/.
const alleBilleder = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/steps/*/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}',
  { eager: true },
);

const billeder = Object.entries(alleBilleder)
  .filter(([sti]) => sti.includes(`/steps/${entry.id}/`))
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([sti, mod]) => {
    const filnavn = sti.split('/').pop() ?? '';
    const alt = filnavn
      .replace(/\.[^.]+$/, '')
      .replace(/[-_]+/g, ' ')
      .trim();
    return { billede: mod.default, alt: `${entry.data.titel}: ${alt}` };
  });

const naboFor = forrige
  ? { titel: forrige.data.titel, slug: forrige.id, order: forrige.data.order }
  : undefined;
const naboNaeste = naeste
  ? { titel: naeste.data.titel, slug: naeste.id, order: naeste.data.order }
  : undefined;

// Bestillings-mail til savværk – kun på yderbeklædning. Yderbeklædning
// (typisk Douglasgran) kan bestilles direkte hos savværket og skære et
// mellemled væk. Mængderne er vejledende template-tal fra estimatet – ikke
// rigtige tal fra et konkret byg.
const erYderbeklaedning = entry.id === 'yderbeklaedning';
let savvaerkEmail: { emne: string; tekst: string } | null = null;
let templateMaal = '';
if (erYderbeklaedning) {
  const maal = [...materialelister.praedefineredeMaal].sort(
    (a, b) => b.laengde_cm * b.bredde_cm - a.laengde_cm * a.bredde_cm,
  )[0];
  templateMaal = `${maal.laengde_cm / 100} × ${maal.bredde_cm / 100} m`.replace(/\./g, ',');
  const talFmt = new Intl.NumberFormat('da-DK', { maximumFractionDigits: 2 });
  const varer = ((maal.materialerPrStep as Record<string, Array<{ materiale: string; maengde: number; enhed: string; note?: string }>>).yderbeklaedning ?? []).map(
    (m) => `- ${m.materiale}: ${talFmt.format(m.maengde)} ${m.enhed}${m.note ? ` (${m.note})` : ''}`,
  );
  const linjer = [
    'Hej',
    '',
    'Jeg skal bruge yderbeklædning til et tiny house og vil gerne bestille / bede om tilbud direkte hos jer som savværk – så jeg skærer et mellemled væk.',
    '',
    'Jeg tænker Douglasgran, ubehandlet (gerne kernetræ), som facadebeklædning.',
    '',
    `VEJLEDENDE MÆNGDER (template-tal for et hus på ${templateMaal} – se OBS nedenfor):`,
    ...varer,
    '',
    'Ønsker:',
    '- Profil: [fx 1-på-2, klink/faldende eller profilhøvlet]',
    '- Dimension: [fx 25×150 mm]',
    '- Tørhed: [lufttørret / ovntørret]',
    '- Længder: gerne faste længder, der passer til facaden',
    '',
    'OBS: Mængderne ovenfor er vejledende template-tal – ikke rigtige tal fra et konkret byg. Tilpas til dit eget hus.',
    '',
    'Giv gerne jeres pris pr. m² (og pr. lbm) direkte fra savværk, samt leveringstid og fragt. Jeg indhenter tilbud fra flere savværker (se cc), så jeg kan sammenligne.',
    '',
    'På forhånd tak.',
    '',
    'Med venlig hilsen',
    '__NAVN__',
  ];
  savvaerkEmail = {
    emne: 'Tilbud/bestilling – Douglasgran yderbeklædning (savværk)',
    tekst: linjer.join('\n'),
  };
}
---

<BaseLayout titel={entry.data.titel} beskrivelse={entry.data.resume}>
  <article class="mx-auto max-w-3xl px-4 py-10">
    <a
      href={href('#byggesteps')}
      class="text-sm font-medium text-skov-600 hover:text-skov-700">← Alle byggesteps</a
    >

    <header class="mt-4">
      <div class="flex items-center gap-3">
        <span
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-skov-600 font-bold text-ler-50"
          >{entry.data.order}</span
        >
        <h1 class="text-3xl font-bold text-ler-900 sm:text-4xl">{entry.data.titel}</h1>
      </div>
      <p class="mt-3 text-lg text-ler-700">{entry.data.resume}</p>
      {
        entry.data.tid && (
          <p class="mt-2 inline-flex items-center gap-1 rounded-full bg-ler-100 px-3 py-1 text-sm text-ler-700">
            ⏱️ Estimeret tid: {entry.data.tid}
          </p>
        )
      }
    </header>

    <section class="prose-tiny mt-8">
      <Content />
    </section>

    <section class="mt-12">
      <h2 class="mb-4 text-2xl font-bold text-ler-900">🧱 Materialer</h2>
      <MaterialTabel materialer={entry.data.materialer} />
      <p class="mt-3 text-sm text-ler-600">
        Vil du have konkrete mængder? Se
        <a href={href('beregner')} class="font-medium text-skov-600 underline">materialelisterne</a>
        og vælg en færdig størrelse.
      </p>
    </section>

    {
      erYderbeklaedning && savvaerkEmail && (
        <section id="bestil-savvaerk" class="mt-12 scroll-mt-20 rounded-2xl border border-skov-600/20 bg-skov-600/5 p-6 sm:p-8">
          <h2 class="flex items-center gap-2 text-2xl font-bold text-ler-900">
            <span aria-hidden="true">🪵</span> Bestil direkte hos savværk
          </h2>
          <p class="mt-3 text-ler-700">
            Yderbeklædning kan du med fordel bestille <strong>direkte hos et savværk</strong> og
            skære et mellemled væk – det giver ofte en bedre pris. Typisk vælges{' '}
            <strong>Douglasgran</strong>: holdbart kernetræ, der kan stå ubehandlet og patinere
            smukt gråt.
          </p>

          <div class="mt-5 rounded-xl border border-ler-200 bg-ler-50/70 p-4 text-sm text-ler-700">
            <p class="font-semibold text-ler-900">Sådan bestiller du smart 🪚</p>
            <ul class="mt-2 list-disc space-y-1 pl-5">
              <li>Bestil <strong>direkte hos savværket</strong> – uden mellemled.</li>
              <li>Angiv <strong>profil, dimension, tørhed</strong> og gerne faste længder.</li>
              <li>Send til <strong>flere savværker</strong> og sæt dem i cc, så de ved, der er konkurrence.</li>
              <li>Spørg til <strong>kernetræ</strong> for bedre holdbarhed på ubehandlet facade.</li>
            </ul>
          </div>

          <p class="mt-4 rounded-lg border border-ler-300 bg-ler-100 px-4 py-3 text-sm text-ler-700">
            ⚠️ Mængderne i e-mailen er <strong>vejledende template-tal</strong> (fra estimatet for
            et hus på {templateMaal}) – <strong>ikke rigtige tal</strong> fra et konkret byg.
            Tilpas altid til dit eget hus.
          </p>

          <BestillingsMail
            emne={savvaerkEmail.emne}
            tekst={savvaerkEmail.tekst}
            tilPlaceholder="salg@savvaerk.dk"
            ccPlaceholder="info@savvaerk2.dk, kontakt@savvaerk3.dk"
            sendLabel="📧 Åbn bestillings-e-mail"
          />
        </section>
      )
    }

    <section class="mt-12">
      <h2 class="mb-4 text-2xl font-bold text-ler-900">🔧 Værktøj</h2>
      <VaerktojsListe vaerktoj={entry.data.vaerktoj} />
    </section>

    <section class="mt-12">
      <h2 class="mb-4 text-2xl font-bold text-ler-900">📷 Billeder</h2>
      <Galleri billeder={billeder} stepTitel={entry.data.titel} />
    </section>

    <StepNav forrige={naboFor} naeste={naboNaeste} />
  </article>
</BaseLayout>
