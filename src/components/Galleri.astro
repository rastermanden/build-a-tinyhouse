---
import { Image } from 'astro:assets';

interface Billede {
  billede: ImageMetadata;
  alt: string;
}

interface Props {
  billeder: Billede[];
  stepTitel: string;
}

const { billeder, stepTitel } = Astro.props;
---

{
  billeder.length > 0 ? (
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
      {billeder.map(({ billede, alt }) => (
        <figure class="overflow-hidden rounded-xl border border-ler-200 bg-ler-100">
          <Image
            src={billede}
            alt={alt}
            widths={[320, 640]}
            sizes="(min-width: 640px) 30vw, 45vw"
            class="h-40 w-full object-cover transition-transform duration-300 hover:scale-105"
          />
        </figure>
      ))}
    </div>
  ) : (
    <div class="rounded-xl border border-dashed border-ler-300 bg-ler-100/60 px-4 py-10 text-center">
      <p class="text-2xl" aria-hidden="true">
        📷
      </p>
      <p class="mt-2 text-sm text-ler-700">
        Der er endnu ikke lagt billeder op for <strong>{stepTitel}</strong>.
      </p>
      <p class="mt-1 text-xs text-ler-500">
        Billeder lægges i mappen <code class="rounded bg-ler-200 px-1">src/assets/steps/</code> for dette step.
      </p>
    </div>
  )
}
