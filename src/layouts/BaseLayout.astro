---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  titel: string;
  beskrivelse?: string;
}

const { titel, beskrivelse = 'Byg dit eget tiny house – en trin-for-trin byggeguide i naturmaterialer, inspireret af småBYG og Jonas.' } = Astro.props;
const fuldTitel = titel === 'Byg dit eget tiny house' ? titel : `${titel} · Byg dit eget tiny house`;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={beskrivelse} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{fuldTitel}</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
